# Wajib: endpoint dan token API Paperclip
PAPERCLIP_API_URL=http://127.0.0.1:3101
PAPERCLIP_API_KEY=replace_with_runtime_or_service_token

# Wajib untuk kirim Telegram (abaikan jika DRY_RUN=1)
TELEGRAM_BOT_TOKEN=replace_with_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_or_channel_id

# Opsional
REPORT_TIMEZONE=Asia/Jakarta
REPORT_MAX_ITEMS=6
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_SEC=5
LOG_FILE=./deliverables/logs/daily-telegram-report.log
DRY_RUN=1
